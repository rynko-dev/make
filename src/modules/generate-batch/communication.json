{
  "url": "https://api.renderbase.dev/api/v1/documents/generate/batch",
  "method": "POST",
  "headers": {
    "Authorization": "Bearer {{connection.accessToken}}",
    "Content-Type": "application/json"
  },
  "body": {
    "templateId": "{{parameters.templateId}}",
    "format": "{{parameters.format}}",
    "documents": "{{map(parameters.documents, 'item', create('variables', omit(item, 'fileName'), 'fileName', item.fileName))}}",
    "teamId": "{{parameters.teamId}}",
    "workspaceId": "{{parameters.workspaceId}}"
  },
  "response": {
    "output": {
      "batchId": "{{body.batchId}}",
      "status": "{{body.status}}",
      "totalJobs": "{{body.totalJobs}}",
      "statusUrl": "{{body.statusUrl}}",
      "estimatedWaitSeconds": "{{body.estimatedWaitSeconds}}"
    }
  }
}
