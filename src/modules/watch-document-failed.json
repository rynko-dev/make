{
  "name": "watchDocumentFailed",
  "label": "Watch Document Failed",
  "description": "Triggers when a document generation fails through Renderbase",
  "type": "trigger",
  "connection": "oauth2",
  "webhook": "documentEvents",
  "parameters": [],
  "static": {
    "events": ["document.failed"]
  },
  "output": [
    { "name": "id", "label": "Event ID", "type": "text" },
    { "name": "type", "label": "Event Type", "type": "text" },
    { "name": "timestamp", "label": "Timestamp", "type": "date" },
    { "name": "data.jobId", "label": "Job ID", "type": "text" },
    { "name": "data.templateId", "label": "Template ID", "type": "text" },
    { "name": "data.templateName", "label": "Template Name", "type": "text" },
    { "name": "data.format", "label": "Format", "type": "text" },
    { "name": "data.status", "label": "Status", "type": "text" },
    { "name": "data.error", "label": "Error Message", "type": "text" },
    { "name": "data.failedAt", "label": "Failed At", "type": "date" }
  ],
  "samples": [
    {
      "id": "evt_sample_123",
      "type": "document.failed",
      "timestamp": "2025-01-15T10:30:00Z",
      "data": {
        "jobId": "job_abc123",
        "templateId": "tmpl_xyz789",
        "templateName": "Invoice Template",
        "format": "pdf",
        "status": "failed",
        "error": "Variable 'customerName' is required but was not provided",
        "failedAt": "2025-01-15T10:30:00Z"
      }
    }
  ]
}
