{
  "name": "getDocument",
  "label": "Get Document",
  "description": "Get details of a document generation job by ID",
  "type": "action",
  "connection": "oauth2",
  "api": {
    "url": "{{base.baseUrl}}/documents/{{parameters.jobId}}",
    "method": "GET",
    "headers": "{{common.headers}}",
    "response": {
      "output": "{{body.data}}"
    }
  },
  "parameters": [
    {
      "name": "jobId",
      "label": "Job ID",
      "type": "text",
      "required": true,
      "help": "The unique ID of the document job to retrieve"
    }
  ],
  "output": [
    { "name": "id", "label": "Job ID", "type": "text" },
    { "name": "status", "label": "Status", "type": "text" },
    { "name": "templateId", "label": "Template ID", "type": "text" },
    { "name": "templateName", "label": "Template Name", "type": "text" },
    { "name": "format", "label": "Format", "type": "text" },
    { "name": "fileName", "label": "File Name", "type": "text" },
    { "name": "downloadUrl", "label": "Download URL", "type": "text" },
    { "name": "fileSize", "label": "File Size (bytes)", "type": "number" },
    { "name": "error", "label": "Error (if failed)", "type": "text" },
    { "name": "createdAt", "label": "Created At", "type": "date" },
    { "name": "completedAt", "label": "Completed At", "type": "date" }
  ],
  "samples": [
    {
      "id": "job_abc123",
      "status": "completed",
      "templateId": "tmpl_xyz789",
      "templateName": "Invoice Template",
      "format": "pdf",
      "fileName": "Invoice-12345.pdf",
      "downloadUrl": "https://api.rynko.dev/v1/documents/job_abc123/download",
      "fileSize": 125000,
      "error": null,
      "createdAt": "2025-01-15T10:30:00Z",
      "completedAt": "2025-01-15T10:30:05Z"
    }
  ]
}
