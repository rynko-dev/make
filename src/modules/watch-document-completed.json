{
  "name": "watchDocumentCompleted",
  "label": "Watch Document Completed",
  "description": "Triggers when a document is successfully generated through Rynko",
  "type": "trigger",
  "connection": "oauth2",
  "webhook": "documentEvents",
  "parameters": [],
  "static": [
    {
      "name": "events",
      "type": "array",
      "default": ["document.generated"]
    }
  ],
  "output": [
    { "name": "id", "label": "Event ID", "type": "text" },
    { "name": "type", "label": "Event Type", "type": "text" },
    { "name": "timestamp", "label": "Timestamp", "type": "date" },
    { "name": "data.jobId", "label": "Job ID", "type": "text" },
    { "name": "data.templateId", "label": "Template ID", "type": "text" },
    { "name": "data.templateName", "label": "Template Name", "type": "text" },
    { "name": "data.format", "label": "Format", "type": "text" },
    { "name": "data.status", "label": "Status", "type": "text" },
    { "name": "data.downloadUrl", "label": "Download URL", "type": "text" },
    { "name": "data.fileSize", "label": "File Size (bytes)", "type": "number" },
    { "name": "data.completedAt", "label": "Completed At", "type": "date" }
  ],
  "samples": [
    {
      "id": "evt_sample_123",
      "type": "document.generated",
      "timestamp": "2025-01-15T10:30:00Z",
      "data": {
        "jobId": "job_abc123",
        "templateId": "tmpl_xyz789",
        "templateName": "Invoice Template",
        "format": "pdf",
        "status": "completed",
        "downloadUrl": "https://api.rynko.dev/v1/documents/job_abc123/download",
        "fileSize": 125000,
        "completedAt": "2025-01-15T10:30:00Z"
      }
    }
  ]
}
