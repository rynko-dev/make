{
  "name": "watchBatchCompleted",
  "label": "Watch Batch Completed",
  "description": "Triggers when a batch of documents is finished generating through Renderbase",
  "type": "trigger",
  "connection": "oauth2",
  "webhook": "documentEvents",
  "parameters": [],
  "static": {
    "events": ["batch.completed"]
  },
  "output": [
    { "name": "id", "label": "Event ID", "type": "text" },
    { "name": "type", "label": "Event Type", "type": "text" },
    { "name": "timestamp", "label": "Timestamp", "type": "date" },
    { "name": "data.batchId", "label": "Batch ID", "type": "text" },
    { "name": "data.templateId", "label": "Template ID", "type": "text" },
    { "name": "data.templateName", "label": "Template Name", "type": "text" },
    { "name": "data.totalDocuments", "label": "Total Documents", "type": "number" },
    { "name": "data.successCount", "label": "Success Count", "type": "number" },
    { "name": "data.failureCount", "label": "Failure Count", "type": "number" },
    { "name": "data.format", "label": "Format", "type": "text" },
    { "name": "data.status", "label": "Status", "type": "text" },
    { "name": "data.downloadUrl", "label": "Download URL (ZIP)", "type": "text" },
    { "name": "data.completedAt", "label": "Completed At", "type": "date" }
  ],
  "samples": [
    {
      "id": "evt_sample_123",
      "type": "batch.completed",
      "timestamp": "2025-01-15T10:30:00Z",
      "data": {
        "batchId": "batch_abc123",
        "templateId": "tmpl_xyz789",
        "templateName": "Invoice Template",
        "totalDocuments": 10,
        "successCount": 9,
        "failureCount": 1,
        "format": "pdf",
        "status": "completed",
        "downloadUrl": "https://api.renderbase.dev/v1/batches/batch_abc123/download",
        "completedAt": "2025-01-15T10:30:00Z"
      }
    }
  ]
}
