{
  "url": "https://api.rynko.dev/api/v1/integration-api/workspaces",
  "method": "GET",
  "headers": {
    "Authorization": "Bearer {{connection.accessToken}}",
    "Content-Type": "application/json"
  },
  "qs": {
    "teamId": "{{ifempty(parameters.teamId, '')}}"
  },
  "response": {
    "iterate": "{{body}}",
    "output": {
      "value": "{{item.id}}",
      "label": "{{item.name}} ({{item.teamName}})"
    }
  }
}
