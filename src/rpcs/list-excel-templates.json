{
  "name": "listExcelTemplates",
  "label": "List Excel Templates",
  "description": "Fetches Excel templates for dynamic dropdowns",
  "connection": "oauth2",
  "api": {
    "url": "{{base.baseUrl}}/templates",
    "method": "GET",
    "headers": "{{common.headers}}",
    "qs": {
      "format": "excel",
      "limit": 100
    },
    "response": {
      "iterate": "{{body.data}}",
      "output": {
        "id": "{{item.id}}",
        "name": "{{item.name}}",
        "description": "{{item.description}}"
      }
    }
  }
}
