{
  "url": "https://api.rynko.dev/api/v1/integration-api/templates/{{parameters.templateId}}/variables",
  "method": "GET",
  "headers": {
    "Authorization": "Bearer {{connection.accessToken}}",
    "Content-Type": "application/json"
  },
  "response": {
    "iterate": "{{body.fields}}",
    "output": {
      "name": "{{item.key}}",
      "label": "{{item.label}}",
      "type": "{{switch(item.type, 'string', 'text', 'text', 'text', 'integer', 'integer', 'number', 'number', 'boolean', 'boolean', 'datetime', 'date', 'text')}}",
      "required": "{{item.required}}",
      "help": "{{item.helpText}}",
      "default": "{{item.default}}"
    }
  }
}
