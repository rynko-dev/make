[
  {
    "name": "workspaceId",
    "label": "Workspace",
    "type": "select",
    "required": false,
    "options": {
      "store": "rpc://listWorkspaces"
    },
    "help": "Optional: Scope webhook to a specific workspace. Leave empty to receive events from all workspaces."
  },
  {
    "name": "events",
    "label": "Event Types",
    "type": "select",
    "required": true,
    "multiple": true,
    "options": [
      {
        "label": "Document Generated",
        "value": "document.generated"
      },
      {
        "label": "Document Failed",
        "value": "document.failed"
      },
      {
        "label": "Document Downloaded",
        "value": "document.downloaded"
      }
    ],
    "help": "Select which events should trigger this webhook"
  }
]
