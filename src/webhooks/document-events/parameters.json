[
  {
    "name": "teamId",
    "label": "Team",
    "type": "select",
    "required": true,
    "options": {
      "store": "rpc://listTeams"
    },
    "help": "Select a team from your Renderbase account"
  },
  {
    "name": "workspaceId",
    "label": "Workspace",
    "type": "select",
    "required": true,
    "options": {
      "store": "rpc://listWorkspaces"
    },
    "help": "Select a workspace to receive webhook events from"
  },
  {
    "name": "events",
    "label": "Event Types",
    "type": "select",
    "required": true,
    "multiple": true,
    "options": [
      {
        "label": "Document Generated",
        "value": "document.generated"
      },
      {
        "label": "Document Failed",
        "value": "document.failed"
      },
      {
        "label": "Document Downloaded",
        "value": "document.downloaded"
      }
    ],
    "help": "Select which events should trigger this webhook"
  }
]
